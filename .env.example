# Supabase (Project Settings → API / API keys)
# Never commit real keys; use .env locally and host env vars in production.
# Vercel: both names MUST start with VITE_ and be enabled for "Production".

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the dashboard "anon" JWT or the new "publishable" key (sb_publishable_…):
VITE_SUPABASE_ANON_KEY=YOUR_ANON_OR_PUBLISHABLE_KEY
# Optional alias (same value as above) if you prefer the name:
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
